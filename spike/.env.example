# Copy to .env and fill in. The backend reads this; the extension NEVER sees the key.
OPENAI_API_KEY=sk-...

# Model ids (pinned; quality over cost). Override if you want.
# Transcription: whisper-1 gives reliable segment timestamps for alignment.
TRANSCRIBE_MODEL=whisper-1
# Vision-capable model for segmentation + synthesis (Structured Outputs).
SYNTH_MODEL=gpt-4o

# Backend port
PORT=8787
