// Sync data model (Phase 1a). Postgres via Prisma.
// Auth.js tables (User/Account/Session/VerificationToken) + app tables.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Auth.js (NextAuth) core ----------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String? // credentials provider (email + password)
  createdAt     DateTime  @default(now())

  accounts        Account[]
  sessions        Session[]
  ownedWorkspaces Workspace[]  @relation("WorkspaceOwner")
  recSessions     KnowledgeSource[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------- App ----------

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique // -> portal subdomain
  ownerId   String
  createdAt DateTime @default(now())

  // P1-M9 — embeddable copilot: a PUBLIC key (safe in client HTML, distinct from the secret
  // recorder ApiToken) + an origin allowlist (empty = allow any, for dev).
  copilotPublicKey      String?  @unique
  copilotAllowedOrigins String[] @default([])
  // Trust setting: show the "Source: <workflow>" citation chip on grounded answers (default on).
  copilotShowCitations  Boolean  @default(true)
  // Appearance (host branding) — flows into the embed snippet's data-sync-* attrs (null = widget default).
  copilotAccent         String?
  copilotTitle          String?
  copilotGreeting       String?
  copilotPosition       String   @default("right")
  copilotLauncherStyle  String   @default("icon") // icon | text | text-outline
  copilotLauncherText   String?
  // Embed detection: the widget pings a heartbeat on mount, so the Studio can show real "live /
  // detected" status (vs. inferring it from query traffic). Null = never seen the snippet load.
  widgetLastSeenAt      DateTime?
  widgetLastSeenOrigin  String?
  // P2 Sense (in-context help) — the per-workspace master toggle. Gates the sense-plan endpoint:
  // off = the widget never probes and the copilot answers exactly as before (route bias only).
  senseEnabled          Boolean  @default(true)
  // P2-M3 "show me" — when on, the widget also HIGHLIGHTS the current step's element on the host
  // page alongside a positional answer (off = text-only). Served to the widget via /v1/copilot/config.
  copilotShowMe         Boolean  @default(false)
  // P4-M0 guided walkthrough — when on, positional answers offer "Walk me through it": the widget
  // highlights each remaining step and follows the user's progress (the user does everything;
  // Sync never acts). Needs Sense. Served to the widget via /v1/copilot/config.
  copilotWalkthrough    Boolean  @default(false)
  // P2-M5 Reason (diagnostic reasoning) — the founder toggle ladder (docs/phase-2-reason.md §5.3):
  // `reasonEnabled` gates the whole diagnostic path (ask-time structured page-state capture, values
  // masked). `reasonImageEnabled` adds the DOM-rendered page image (the most sensitive capture —
  // OFF by default; flipping it surfaces the disclosure snippet in Studio). `reasonIncludeValues`
  // unmasks typed field values in the capture (hard floors apply regardless: passwords are never
  // captured, card/SSN patterns always masked). All served to the widget via /v1/copilot/config.
  reasonEnabled         Boolean  @default(true)
  // Image tier default ON since 2026-07-16 (visual-only state — met/unmet checklists, banners — is
  // where diagnosis quality lives); the founder still owns the toggle + the disclosure snippet.
  reasonImageEnabled    Boolean  @default(true)
  reasonIncludeValues   Boolean  @default(false)

  owner            User              @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  tokens           ApiToken[]
  sessions         KnowledgeSource[]
  coverageGaps     CoverageGap[]
  copilotApprovals CopilotApproval[]
  copilotQueries   CopilotQuery[]
  walkthroughs     CopilotWalkthrough[]
}

model ApiToken {
  id          String   @id @default(cuid())
  workspaceId String
  hashedToken String   @unique
  label       String?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model KnowledgeSource {
  // The per-recording source record (architecture: "KnowledgeSource"). Module 1 output.
  // Table kept as "RecSession" via @@map so existing data is preserved.
  id          String   @id @default(cuid())
  workspaceId String
  createdById String
  kind        String   @default("workflow") // workflow | narration | video
  status      String   @default("uploaded") // uploaded | processing | ready | done | error  (ready = KB built + segmented, candidates available, no articles yet)
  title       String? // founder-given label for the recording (null = fall back to appBaseUrl)
  appBaseUrl  String?
  manifest    Json // raw capture manifest (events, markers, meta)
  transcript  Json? // persisted narration transcript { text, segments[] } — for retrieval
  error       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt // last touch (status flips included) — drives the "stalled processing" surface

  workspace        Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy        User              @relation(fields: [createdById], references: [id])
  items            KnowledgeItem[]
  copilotApprovals CopilotApproval[]

  @@map("RecSession")
}

model KnowledgeItem {
  // Module 2: the normalized, indexed unit of knowledge. One per step (workflow) or topic (narration).
  id          String   @id @default(cuid())
  sourceId    String
  workspaceId String
  kind         String // step | topic
  orderIndex   Int
  text         String // searchable content — keyword scoring AND the embedding input (already folds in narration via distilledStepText)
  data         Json // step: { instruction, detail, route, narration, screenshotFile, bbox } (distilled — 2026-06-27; legacy pre-distillation rows: { event, narration }) ; topic: { spanText, startMs, endMs }
  segmentIndex Int? // workflow this item belongs to (Path 2 — persisted segmentation, promoted toward Option C)
  segmentTitle String?
  // P1-M3 hybrid retrieval — text-embedding-3-small(1536) over `text`, written by the worker at KB
  // build via raw SQL (Prisma can't write Unsupported). Nullable: rows without a vector (embed-call
  // failure, pre-upgrade data) stay retrievable through keyword scoring.
  embedding    Unsupported("vector(1536)")?
  createdAt    DateTime @default(now())

  source KnowledgeSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([sourceId])
}

model CoverageGap {
  // Module 3.2: a prompt-to-article request the KB could NOT cover → "record this next".
  id          String   @id @default(cuid())
  workspaceId String
  prompt      String // the requested topic / the end-user question
  reason      String? // why the AI declined (grounding gap)
  status      String   @default("open") // open | resolved
  source      String   @default("prompt") // prompt (Text->Article) | copilot (P1-M10)
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model CopilotApproval {
  // P1-M5: the copilot trust gate. One row = one workflow approved for the copilot to answer from.
  // Keyed by (sourceId, segmentIndex) so approval SURVIVES KnowledgeItem delete+recreate on reprocess
  // (the worker deletes+recreates items, which would wipe a per-item flag). Absence = not approved.
  id           String   @id @default(cuid())
  workspaceId  String
  sourceId     String // KnowledgeSource the workflow belongs to
  segmentIndex Int // the workflow within that source (KnowledgeItem.segmentIndex)
  segmentTitle String? // snapshot of the title at approval time (display/audit)
  approvedById String? // who approved (audit)
  createdAt    DateTime @default(now())

  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  source    KnowledgeSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([sourceId, segmentIndex])
  @@index([workspaceId])
}

model CopilotQuery {
  // P1-M10: a logged end-user question to the copilot (feedback loop + analytics).
  id          String   @id @default(cuid())
  workspaceId String
  question    String
  answered    Boolean // true = covered/answered, false = declined
  feedback    String? // up | down | null (thumbs from the widget)
  contextPath String? // P1-M8: host-app path the end-user was on when they asked (e.g. "/settings")
  // P2 Sense — the localization outcome attached to this question (P2-M4 step-friction analytics).
  // A row where the probe localized the user records WHERE ("workflow W, step k") and whether the
  // answer actually USED that position. `senseUsed`: used | ignored (hypotheses sent, answer was
  // about something else — must NOT count as step friction) | none (probe ran, nothing matched —
  // a passive drift signal). Null = pre-Sense row / no probe ran.
  senseSourceId     String?
  senseSegmentIndex Int?
  senseStep         Int? // 1-based step index within the workflow
  senseConfidence   Float?
  senseUsed         String?
  // P2-M5 Reason — why the diagnostic path fired for this question: intent (diagnostic wording) |
  // blocked (the current step's target was disabled) | escalation (the fast path declined and the
  // widget retried with evidence). Null = the fast path answered. `reasonImage` = whether the
  // user's rendered page image rode along on the diagnostic call.
  reasonTrigger     String?
  reasonImage       Boolean?
  createdAt   DateTime @default(now())

  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  citations QueryCitation[]

  @@index([workspaceId])
}

model CopilotWalkthrough {
  // P4-M0: one row per guided-walkthrough RUN (a session, not a query — the optional queryId keeps
  // the join to the question that offered it). Written by POST /v1/copilot/walkthrough: `started`
  // creates the row (workflow key verified against CopilotApproval first — no-leak), progress
  // events bump lastStep + the auto/manual counters, terminal events set the outcome. A row still
  // `active` past the widget's 30-min session TTL reads as abandoned (no sweeper by design).
  id             String   @id @default(cuid())
  workspaceId    String
  sourceId       String // KnowledgeSource the workflow belongs to
  segmentIndex   Int // the workflow within that source
  segmentTitle   String? // snapshot at start (display/audit, approval-sourced — never the wire)
  queryId        String? // originating CopilotQuery, when known
  startStep      Int // where the user entered (mid-workflow entry via Sense)
  totalSteps     Int
  lastStep       Int // furthest step reached
  autoAdvances   Int      @default(0) // steps detected automatically (measures detection quality for P4-M2)
  manualAdvances Int      @default(0) // steps advanced via the Next button
  outcome        String   @default("active") // active | completed | aborted | stalled
  stalledAtStep  Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model QueryCitation {
  // Analytics: one row per workflow the copilot CITED to answer a question. Powers
  // "Top workflows by citations" (group by sourceId+segmentIndex). Cascades from the
  // parent CopilotQuery (which cascades from Workspace), so workspace delete cleans up.
  id           String   @id @default(cuid())
  queryId      String
  workspaceId  String // denormalized for direct per-workspace aggregation (cf. KnowledgeItem)
  sourceId     String // KnowledgeSource the cited workflow belongs to
  segmentIndex Int? // the workflow within that source (KnowledgeItem.segmentIndex)
  segmentTitle String? // snapshot of the workflow title at answer time (display)
  createdAt    DateTime @default(now())

  query CopilotQuery @relation(fields: [queryId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([queryId])
}
