# Copy to .env (root) for local dev. Each service also reads from env at runtime.
# This file is the single source of truth for required env vars.

# --- Logging (all Node services: api, worker, Studio server) ---
# Level threshold: trace | debug | info | warn | error | fatal | silent.
# Unset = debug in development, info in production (NODE_ENV). Set to quieten/loosen a service.
# LOG_LEVEL=info
# Output shape: unset = pretty in a dev TTY, JSON in prod / non-TTY. Force with 1 (pretty) or 0 (JSON).
# LOG_PRETTY=1
# Studio CLIENT (browser) log level — build-time, inlined into the client bundle. Default: warn in prod.
# NEXT_PUBLIC_LOG_LEVEL=debug

# --- Database (matches docker-compose) ---
DATABASE_URL=postgresql://flowbuddy:flowbuddy@localhost:5432/flowbuddy

# --- Redis / queue (matches docker-compose) ---
REDIS_URL=redis://localhost:6379

# --- Object storage (S3-compatible) ---
# Local dev uses MinIO (docker-compose); prod points these at Cloudflare R2.
# Local MinIO defaults: endpoint http://localhost:9000, key/secret minioadmin/minioadmin.
R2_ENDPOINT=http://localhost:9000
R2_REGION=auto
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_BUCKET=flowbuddy-artifacts
# R2 only (prod): account id is part of the R2 endpoint URL.
R2_ACCOUNT_ID=

# --- OpenAI (worker only) ---
OPENAI_API_KEY=
TRANSCRIBE_MODEL=whisper-1
SYNTH_MODEL=gpt-4o
# P1-M3 hybrid retrieval — optional; empty = text-embedding-3-small. Must match vector(1536).
# EMBED_MODEL=text-embedding-3-small

# --- Auth.js v5 (web/Studio) ---
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# --- api (optional) ---
# Studio origin exempted from copilot origin allowlists (the in-Studio real-widget tester).
# Defaults to http://localhost:3000; set to the deployed Studio URL in prod (render.yaml).
# FLOWBUDDY_STUDIO_URL=http://localhost:3000
