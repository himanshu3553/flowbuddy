# Copy to .env (root) for local dev. Each service also reads from env at runtime.
# This file is the single source of truth for required env vars.

# --- Database (matches docker-compose) ---
DATABASE_URL=postgresql://sync:sync@localhost:5432/sync

# --- Redis / queue (matches docker-compose) ---
REDIS_URL=redis://localhost:6379

# --- Object storage (S3-compatible) ---
# Local dev uses MinIO (docker-compose); prod points these at Cloudflare R2.
# Local MinIO defaults: endpoint http://localhost:9000, key/secret minioadmin/minioadmin.
R2_ENDPOINT=http://localhost:9000
R2_REGION=auto
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_BUCKET=sync-artifacts
# R2 only (prod): account id is part of the R2 endpoint URL.
R2_ACCOUNT_ID=

# --- OpenAI (worker only) ---
OPENAI_API_KEY=
TRANSCRIBE_MODEL=whisper-1
SYNTH_MODEL=gpt-4o

# --- Auth.js (web/Studio) ---
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
