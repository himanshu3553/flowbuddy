{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "@sync/db#build": {
      "cache": false
    },
    "@sync/shared#build": {
      "cache": false
    },
    "@sync/synthesis#build": {
      "cache": false
    },
    "@sync/api#build": {
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {}
  }
}
